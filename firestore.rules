rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Data Model
    // ===============================================================
    // users/{userId}
    //   - userId: string
    //   - name: string
    //   - email: string
    //   - shopName: string
    //
    // shops/{shopId}
    //   - shopId: string
    //   - ownerId: string
    //   - shopName: string
    //   - createdAt: timestamp
    //
    // products/{productId}
    //   - productId: string
    //   - shopId: string
    //   - name: string
    //   - price: number
    //   - image: string
    //
    // orders/{orderId}
    //   - orderId: string
    //   - shopId: string
    //   - productId: string
    //   - customerName: string
    //   - status: string

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sylhetkarateAziz8788@gmail.com" && request.auth.token.email_verified == true));
    }

    function validString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function hasOnlyFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId) &&
        hasRequiredFields(['userId', 'name', 'email', 'shopName']) &&
        hasOnlyFields(['userId', 'name', 'email', 'shopName', 'role']) &&
        request.resource.data.userId == request.auth.uid &&
        validString('name', 1, 100) &&
        validString('email', 5, 254) &&
        validString('shopName', 1, 100);

      allow update: if (isOwner(userId) || isAdmin()) &&
        hasRequiredFields(['userId', 'name', 'email', 'shopName']) &&
        hasOnlyFields(['userId', 'name', 'email', 'shopName', 'role']) &&
        request.resource.data.userId == resource.data.userId &&
        validString('name', 1, 100) &&
        validString('email', 5, 254) &&
        validString('shopName', 1, 100);

      allow delete: if isAdmin();
    }

    // shops
    match /shops/{shopId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        hasRequiredFields(['shopId', 'ownerId', 'shopName', 'createdAt']) &&
        hasOnlyFields(['shopId', 'ownerId', 'shopName', 'createdAt']) &&
        request.resource.data.shopId == shopId &&
        request.resource.data.ownerId == request.auth.uid &&
        validString('shopName', 1, 100) &&
        request.resource.data.createdAt is timestamp;

      allow update: if (isAdmin() || request.auth.uid == resource.data.ownerId) &&
        hasRequiredFields(['shopId', 'ownerId', 'shopName', 'createdAt']) &&
        hasOnlyFields(['shopId', 'ownerId', 'shopName', 'createdAt']) &&
        request.resource.data.shopId == resource.data.shopId &&
        request.resource.data.ownerId == resource.data.ownerId &&
        validString('shopName', 1, 100) &&
        request.resource.data.createdAt is timestamp;

      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.ownerId);
    }

    // products
    match /products/{productId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        hasRequiredFields(['productId', 'shopId', 'name', 'price', 'image']) &&
        hasOnlyFields(['productId', 'shopId', 'name', 'price', 'image']) &&
        request.resource.data.productId == productId &&
        validString('name', 1, 200) &&
        request.resource.data.price is number &&
        request.resource.data.price >= 0 &&
        validString('image', 1, 2048) &&
        request.auth.uid == get(/databases/$(database)/documents/shops/$(request.resource.data.shopId)).data.ownerId;

      allow update: if isAuthenticated() &&
        hasRequiredFields(['productId', 'shopId', 'name', 'price', 'image']) &&
        hasOnlyFields(['productId', 'shopId', 'name', 'price', 'image']) &&
        request.resource.data.productId == resource.data.productId &&
        request.resource.data.shopId == resource.data.shopId &&
        validString('name', 1, 200) &&
        request.resource.data.price is number &&
        request.resource.data.price >= 0 &&
        validString('image', 1, 2048) &&
        (isAdmin() || request.auth.uid == get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId);

      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId);
    }

    // orders
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId);

      allow create: if isAuthenticated() &&
        hasRequiredFields(['orderId', 'shopId', 'productId', 'customerName', 'status']) &&
        hasOnlyFields(['orderId', 'shopId', 'productId', 'customerName', 'status']) &&
        request.resource.data.orderId == orderId &&
        validString('customerName', 1, 100) &&
        validString('status', 1, 40) &&
        exists(/databases/$(database)/documents/shops/$(request.resource.data.shopId)) &&
        exists(/databases/$(database)/documents/products/$(request.resource.data.productId));

      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId);
      allow delete: if isAdmin();
    }

    // Optional legacy support for existing tenant reads in the app.
    match /tenants/{tenantId} {
      allow read: if isAuthenticated();
    }
  }
}
