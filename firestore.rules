rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users/{userId}
    // - userId, name, email, phone, shopId
    // shops/{shopId}
    // - shopId, ownerId, shopName, shopSlug, createdAt
    // products/{productId}
    // - productId, shopId, name, description, price, stock, image, category
    // orders/{orderId}
    // - orderId, shopId, productId, customerName, phone, address,
    //   paymentMethod, orderStatus, createdAt

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sylhetkarateAziz8788@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function ownsShop(shopId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/shops/$(shopId)) &&
        get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;
    }

    function validPaymentMethod(field) {
      return request.resource.data[field] in ['Cash on Delivery', 'bKash', 'Nagad'];
    }

    function validOrderStatus(field) {
      return request.resource.data[field] in ['Pending', 'Processing', 'Delivered', 'Cancelled'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId) &&
        hasRequiredFields(['userId', 'name', 'email', 'phone', 'shopId']) &&
        hasOnlyFields(['userId', 'name', 'email', 'phone', 'shopId', 'role']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.shopId is string &&
        validString('name', 1, 100) &&
        validString('email', 5, 254) &&
        validString('phone', 7, 20);

      allow update: if (isOwner(userId) || isAdmin()) &&
        hasRequiredFields(['userId', 'name', 'email', 'phone', 'shopId']) &&
        hasOnlyFields(['userId', 'name', 'email', 'phone', 'shopId', 'role']) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.shopId == resource.data.shopId &&
        validString('name', 1, 100) &&
        validString('email', 5, 254) &&
        validString('phone', 7, 20);

      allow delete: if isAdmin();
    }

    match /shops/{shopId} {
      allow read: if true;

      allow create: if isAuthenticated() &&
        hasRequiredFields(['shopId', 'ownerId', 'shopName', 'shopSlug', 'createdAt']) &&
        hasOnlyFields(['shopId', 'ownerId', 'shopName', 'shopSlug', 'createdAt']) &&
        request.resource.data.shopId == shopId &&
        request.resource.data.ownerId == request.auth.uid &&
        validString('shopName', 1, 100) &&
        validString('shopSlug', 1, 120) &&
        request.resource.data.createdAt is timestamp;

      allow update: if (isAdmin() || request.auth.uid == resource.data.ownerId) &&
        hasRequiredFields(['shopId', 'ownerId', 'shopName', 'shopSlug', 'createdAt']) &&
        hasOnlyFields(['shopId', 'ownerId', 'shopName', 'shopSlug', 'createdAt']) &&
        request.resource.data.shopId == resource.data.shopId &&
        request.resource.data.ownerId == resource.data.ownerId &&
        validString('shopName', 1, 100) &&
        validString('shopSlug', 1, 120);

      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.ownerId);
    }

    match /products/{productId} {
      allow read: if true;

      allow create: if isAuthenticated() &&
        hasRequiredFields(['productId', 'shopId', 'name', 'description', 'price', 'stock', 'image', 'category']) &&
        hasOnlyFields(['productId', 'shopId', 'name', 'description', 'price', 'stock', 'image', 'category']) &&
        request.resource.data.productId == productId &&
        request.resource.data.shopId is string &&
        validString('name', 1, 200) &&
        validString('description', 1, 5000) &&
        request.resource.data.price is number && request.resource.data.price >= 0 &&
        request.resource.data.stock is int && request.resource.data.stock >= 0 &&
        validString('image', 1, 2048) &&
        validString('category', 1, 100) &&
        ownsShop(request.resource.data.shopId);

      allow update: if isAuthenticated() &&
        hasRequiredFields(['productId', 'shopId', 'name', 'description', 'price', 'stock', 'image', 'category']) &&
        hasOnlyFields(['productId', 'shopId', 'name', 'description', 'price', 'stock', 'image', 'category']) &&
        request.resource.data.productId == resource.data.productId &&
        request.resource.data.shopId == resource.data.shopId &&
        validString('name', 1, 200) &&
        validString('description', 1, 5000) &&
        request.resource.data.price is number && request.resource.data.price >= 0 &&
        request.resource.data.stock is int && request.resource.data.stock >= 0 &&
        validString('image', 1, 2048) &&
        validString('category', 1, 100) &&
        (isAdmin() || ownsShop(resource.data.shopId));

      allow delete: if isAdmin() || ownsShop(resource.data.shopId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || ownsShop(resource.data.shopId);

      allow create: if
        hasRequiredFields(['orderId', 'shopId', 'productId', 'customerName', 'phone', 'address', 'paymentMethod', 'orderStatus', 'createdAt']) &&
        hasOnlyFields(['orderId', 'shopId', 'productId', 'customerName', 'phone', 'address', 'paymentMethod', 'orderStatus', 'createdAt']) &&
        request.resource.data.orderId == orderId &&
        request.resource.data.shopId is string &&
        request.resource.data.productId is string &&
        validString('customerName', 1, 100) &&
        validString('phone', 7, 20) &&
        validString('address', 3, 500) &&
        validPaymentMethod('paymentMethod') &&
        validOrderStatus('orderStatus') &&
        request.resource.data.createdAt is timestamp &&
        exists(/databases/$(database)/documents/shops/$(request.resource.data.shopId)) &&
        exists(/databases/$(database)/documents/products/$(request.resource.data.productId));

      allow update: if isAdmin() || ownsShop(resource.data.shopId);
      allow delete: if isAdmin() || ownsShop(resource.data.shopId);
    }

    match /tenants/{tenantId} {
      allow read: if isAuthenticated();
    }
  }
}
