rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isAuthenticated() &&
        ((userDoc.data != null && userDoc.data.role == 'admin') ||
         (request.auth.token.email == "sylhetkarateAziz8788@gmail.com" && request.auth.token.email_verified == true));
    }

    function isShopOwner(shopId) {
      let shopDoc = get(/databases/$(database)/documents/shops/$(shopId));
      return isAuthenticated() && shopDoc.exists && shopDoc.data.ownerUid == request.auth.uid;
    }

    function canAccessShop(shopId) {
      return shopId != null && (isAdmin() || isShopOwner(shopId));
    }

    // Rules
    match /shops/{shopId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && canAccessShop(request.resource.data.shopId);
      allow update, delete: if isAdmin() || (isAuthenticated() && isShopOwner(resource.data.shopId));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    // New rules for other collections
    match /orders/{orderId} {
      allow read, write: if isAdmin() || (isAuthenticated() && canAccessShop(request.resource.data.shopId != null ? request.resource.data.shopId : resource.data.shopId));
    }

    match /coupons/{couponId} {
      allow read, write: if isAdmin() || (isAuthenticated() && canAccessShop(request.resource.data.shopId != null ? request.resource.data.shopId : resource.data.shopId));
    }

    match /banners/{bannerId} {
      allow read, write: if isAdmin() || (isAuthenticated() && canAccessShop(request.resource.data.shopId != null ? request.resource.data.shopId : resource.data.shopId));
    }

    match /collections/{collectionId} {
      allow read, write: if isAdmin() || (isAuthenticated() && canAccessShop(request.resource.data.shopId != null ? request.resource.data.shopId : resource.data.shopId));
    }

    match /flashSales/{flashSaleId} {
      allow read, write: if isAdmin() || (isAuthenticated() && canAccessShop(request.resource.data.shopId != null ? request.resource.data.shopId : resource.data.shopId));
    }

    match /customers/{customerId} {
      allow read, write: if isAdmin() || (isAuthenticated() && canAccessShop(request.resource.data.shopId != null ? request.resource.data.shopId : resource.data.shopId));
    }

    match /sales/{saleId} {
      allow read, write: if isAdmin() || (isAuthenticated() && canAccessShop(request.resource.data.shopId != null ? request.resource.data.shopId : resource.data.shopId));
    }

    match /expenses/{expenseId} {
      allow read, write: if isAdmin() || (isAuthenticated() && canAccessShop(request.resource.data.shopId != null ? request.resource.data.shopId : resource.data.shopId));
    }
  }
}
