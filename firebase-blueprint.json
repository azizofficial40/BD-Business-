{
  "entities": {
    "Shop": {
      "title": "Shop",
      "description": "Represents a shop in the multi-tenant system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["id", "name", "ownerUid", "slug"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["id", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a product in a shop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "shopId", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "shopId"]
    }
  },
  "firestore": {
    "/shops/{shopId}": {
      "schema": { "$ref": "Shop" },
      "description": "Shops collection"
    },
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "Users collection"
    },
    "/shops/{shopId}/products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Products collection"
    },
    "/shops/{shopId}/orders/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Orders collection"
    }
  }
}
