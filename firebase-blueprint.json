{
  "entities": {
    "Shop": {
      "title": "Shop",
      "description": "A shop entity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["id", "name", "ownerUid"]
    },
    "Product": {
      "title": "Product",
      "description": "A product entity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "shopId", "name"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "A user profile entity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "email"]
    }
  },
  "firestore": {
    "/shops/{shopId}": {
      "schema": { "$ref": "Shop" },
      "description": "Shops collection"
    },
    "/products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Products collection"
    },
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "Users collection"
    }
  }
}
